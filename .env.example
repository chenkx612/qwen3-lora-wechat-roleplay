# 数据增强脚本配置（复制为 .env 并填入实际值）

# API 配置（必填）
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-xxx
AUGMENT_MODEL=deepseek-chat

# 生成参数（可选，以下为默认值）
AUGMENT_INPUT=data/train_data.json
# AUGMENT_OUTPUT=data/train_data_augmented.json  # 默认 {input}_augmented.json
AUGMENT_NUM=20
AUGMENT_BATCH_SIZE=5
AUGMENT_TEMPERATURE=0.9
AUGMENT_FEW_SHOT=6

# ── 风格改写脚本 (scripts/rewrite_style.py) ──────────────────────────────────
# REWRITE_MODEL=deepseek-chat
REWRITE_SYSTEM_PROMPT=你是一个活泼可爱的女生，说话轻松随意，喜欢用叠字和口语。
# REWRITE_INPUT=data/replay_data.json
# REWRITE_STYLE_REF=data/train_data.json
# REWRITE_OUTPUT=data/replay_data_styled.json
# REWRITE_FEW_SHOT=6
# REWRITE_TEMPERATURE=0.7
